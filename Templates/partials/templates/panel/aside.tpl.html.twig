{# ./src/Neo_Admin/Templates/partials/templates/panel/aside.tpl.html.twig #}

{% import 'partials/macros/icon.macro.html.twig' as Icon %}
{% import 'partials/macros/badge.macro.html.twig' as Badge %}

<div class="panel-brand">
    {{ Icon.icon(app.icon, {w: 6, h: 6}) }}
    <span class="panel-brand-name">
        {{ app.name }}
    </span>
</div>

<div class="panel-nav-scroll">
    <nav class="panel-nav">
        {% for key, group in navigationItems() %}
            <div class="panel-nav-group">
                <span class="panel-nav-group-label">{{ group.label }}</span>

                {% for link in group.links %}
                    {% set parts = link.route ? link.route|split('.') : [] %}
                    {% set route_prefix = parts|length > 1 ? (parts|slice(0, parts|length - 1)|join('.') ~ '.') : null %}
                    {% set is_active = route_prefix is not null and currentRoute() starts with route_prefix %}

                    <a href="{{ link.route ? path(link.route) : '#' }}" class="panel-nav-link{{ is_active ? ' active' : '' }}">
                        {{ Icon.icon(link.icon, {w: 5, h: 5}) }}
                        <span>{{ link.label }}</span>
                    </a>
                {% endfor %}
            </div>
        {% endfor %}
    </nav>
</div>

<div class="panel-user">
    <div class="panel-user-avatar">
        {{ getAdministrator().initials }}
    </div>

    <div class="panel-user-info">
        <span class="panel-user-name">
            {{ (getAdministrator().display_fullname)|default(getAdministrator().username) }}
        </span>
        <span class="panel-user-role">
            {% set role = getAdministrator().role %}
            {{ Badge.badge(role.label, {color: role.textColor, background: role.backgroundColor}) }}
        </span>
    </div>

    <a href="{{ path('auth.logout.index') }}" class="panel-logout-icon" aria-label="{{ translate('Déconnexion') }}">
        {{ Icon.icon('log-out', {w: 4, h: 4}) }}
    </a>
</div>