{# ./src/Neo_Admin/Templates/pages/panel/preferences/locale.html.twig #}

{% extends "layouts/panel.layout.html.twig" %}
{% import 'partials/macros/icon.macro.html.twig' as Icon %}
{% import 'partials/macros/form.macro.html.twig' as Form %}
{% import 'partials/macros/breadcrumb.macro.html.twig' as Breadcrumb %}

{% set page = {
    title: translate('Préférences')
} %}

{% block panelContent %}

    {{ Breadcrumb.breadcrumb([
        { label: translate('Tableau de bord'), route: 'panel.dashboard.index' },
        { label: translate('Préférences'), route: 'panel.preference.index' },
        { label: translate('Langue') }
    ]) }}

    {{ Form.simple_field('locale_search', {
        type: 'search',
        icon: 'search',
        placeholder: translate('Rechercher une langue'),
        attr: {'live-search': 'locale-search'},
        wrapper_class: 'search-field'
    }) }}

    <div class="locale-grid">
        {% for locale in locales %}
            <a href="{{ path('panel.preference.locale.change', {locale: locale.code}) }}"
               class="locale-card{{ currentLocale == locale.code ? ' active' : '' }}"
               locale-search="">
                <span class="locale-card-code">{{ locale.code|upper }}</span>
                <span class="locale-card-label">{{ translate(locale.label) }}</span>
                {% if currentLocale == locale.code %}
                    <span class="locale-card-check">{{ Icon.icon('check', {w: 4, h: 4}) }}</span>
                {% endif %}
            </a>
        {% endfor %}
    </div>

    <script type="text/javascript" src="{{ asset('js/components/LiveSearch.js') }}"></script>
{% endblock %}