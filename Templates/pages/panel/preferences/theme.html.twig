{# ./src/Neo_Admin/Templates/pages/panel/preferences/theme.html.twig #}

{% extends "layouts/panel.layout.html.twig" %}
{% import 'partials/macros/icon.macro.html.twig' as Icon %}
{% import 'partials/macros/badge.macro.html.twig' as Badge %}

{% block panelContent %}
    <a href="{{ path('panel.preference.index') }}" class="page-back-link">
        {{ Icon.icon('arrow-left', {w: 4, h: 4}) }}
        {{ translate('Préférences') }}
    </a>

    <div class="page-header">
        <h1 class="page-header-title">
            {{ translate('Thème') }}
            {{ Badge.badge(translate('Bientôt disponible'), {color: '#a16207', background: '#fef9c3'}) }}
        </h1>
        <p class="page-header-subtitle">{{ translate("Choisis l'apparence de l'interface d'administration.") }}</p>
    </div>

    <div class="theme-preview-grid">
        <div class="theme-preview-card">
            <div class="theme-preview-swatch theme-preview-swatch-light"></div>
            <div class="theme-preview-label">
                {{ Icon.icon('sun', {w: 4, h: 4}) }}
                <span>{{ translate('Clair') }}</span>
            </div>
        </div>

        <div class="theme-preview-card">
            <div class="theme-preview-swatch theme-preview-swatch-dark"></div>
            <div class="theme-preview-label">
                {{ Icon.icon('moon', {w: 4, h: 4}) }}
                <span>{{ translate('Sombre') }}</span>
            </div>
        </div>
    </div>
{% endblock %}