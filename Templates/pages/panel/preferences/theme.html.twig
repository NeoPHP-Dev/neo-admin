{# ./src/Neo_Admin/Templates/pages/panel/preferences/theme.html.twig #}

{% extends "layouts/panel.layout.html.twig" %}
{% import 'partials/macros/icon.macro.html.twig' as Icon %}
{% import 'partials/macros/badge.macro.html.twig' as Badge %}
{% import 'partials/macros/breadcrumb.macro.html.twig' as Breadcrumb %}

{% set page = {
    title: translate('Thème')
} %}

{% block panelContent %}
    {{ Breadcrumb.breadcrumb([
        { label: translate('Tableau de bord'), route: 'panel.dashboard.index' },
        {label: translate('Préférences'), route: 'panel.preference.index'},
        {label: translate('Thème')}
    ]) }}

    <div class="theme-preview-grid">
        <a href="{{ path('panel.preference.theme.change', {theme: 'light'}) }}"
           class="theme-preview-card{{ currentTheme == 'light' ? ' active' : '' }}">
            <div class="theme-preview-swatch theme-preview-swatch-light"></div>
            <div class="theme-preview-label">
                {{ Icon.icon('sun', {w: 4, h: 4}) }}
                <span>{{ translate('Clair') }}</span>
                {% if currentTheme == 'light' %}
                    {{ Icon.icon('check', {w: 4, h: 4}) }}
                {% endif %}
            </div>
        </a>

        <a href="{{ path('panel.preference.theme.change', {theme: 'dark'}) }}"
           class="theme-preview-card{{ currentTheme == 'dark' ? ' active' : '' }}">
            <div class="theme-preview-swatch theme-preview-swatch-dark"></div>
            <div class="theme-preview-label">
                {{ Icon.icon('moon', {w: 4, h: 4}) }}
                <span>{{ translate('Sombre') }}</span>
                {% if currentTheme == 'dark' %}
                    {{ Icon.icon('check', {w: 4, h: 4}) }}
                {% endif %}
            </div>
        </a>
    </div>
{% endblock %}