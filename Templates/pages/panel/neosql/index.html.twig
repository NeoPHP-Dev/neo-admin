{# ./src/Neo_Admin/Templates/pages/panel/neosql/index.html.twig #}

{% extends "layouts/panel.layout.html.twig" %}
{% import 'partials/macros/icon.macro.html.twig' as Icon %}
{% import 'partials/macros/breadcrumb.macro.html.twig' as Breadcrumb %}

{% block panelContent %}
    {{ Breadcrumb.breadcrumb([
        { label: translate('Tableau de bord'), route: 'panel.dashboard.index' },
        { label: 'NeoSQL' }
    ]) }}

    <div class="neosql-table-grid">
        {% for table in tables %}
            <a href="{{ path('panel.neosql.table.show', {table: table.name}) }}" class="neosql-table-card">
                <span class="neosql-table-icon">{{ Icon.icon('table', {w: 5, h: 5}) }}</span>
                <div class="neosql-table-body">
                    <span class="neosql-table-name">{{ table.name }}</span>
                    <span class="neosql-table-meta">
                        {{ table.columnCount }} {{ translate('colonnes') }} · {{ table.rowCount }} {{ translate('lignes') }}
                    </span>
                </div>
                <span class="neosql-table-arrow">{{ Icon.icon('chevron-right', {w: 4, h: 4}) }}</span>
            </a>
        {% endfor %}
    </div>
{% endblock %}