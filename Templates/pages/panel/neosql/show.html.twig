{# ./src/Neo_Admin/Templates/pages/panel/neosql/show.html.twig #}

{% extends "layouts/panel.layout.html.twig" %}
{% import 'partials/macros/icon.macro.html.twig' as Icon %}
{% import 'partials/macros/breadcrumb.macro.html.twig' as Breadcrumb %}

{% block panelContent %}
    {{ Breadcrumb.breadcrumb([
        { label: translate('Tableau de bord'), route: 'panel.dashboard.index' },
        { label: 'NeoSQL', route: 'panel.neosql.index' },
        { label: table }
    ]) }}

    <div class="neosql-columns-section">
        <h2 class="neosql-section-title">{{ translate('Colonnes') }}</h2>
        <div class="neosql-table-wrap">
            <table class="neosql-table">
                <thead>
                <tr>
                    <th>{{ translate('Nom') }}</th>
                    <th>{{ translate('Type') }}</th>
                    <th>{{ translate('Nullable') }}</th>
                    <th>{{ translate('Clé') }}</th>
                    <th>{{ translate('Défaut') }}</th>
                </tr>
                </thead>
                <tbody>
                {% for col in columns %}
                    <tr>
                        <td class="neosql-cell-strong">{{ col.name }}</td>
                        <td class="neosql-cell-mono">{{ col.type }}</td>
                        <td>{{ col.nullable ? translate('Oui') : translate('Non') }}</td>
                        <td>{{ col.key }}</td>
                        <td class="neosql-cell-mono">{{ col.default ?? '—' }}</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <div class="neosql-data-section">
        <div class="neosql-section-header">
            <h2 class="neosql-section-title">{{ translate('Données') }}</h2>
            <span class="neosql-section-meta">{{ total }} {{ translate('lignes au total') }}</span>
        </div>

        <div class="neosql-table-wrap">
            <table class="neosql-table">
                <thead>
                <tr>
                    {% for col in columns %}
                        <th>{{ col.name }}</th>
                    {% endfor %}
                </tr>
                </thead>
                <tbody>
                {% for row in rows %}
                    <tr>
                        {% for col in columns %}
                            <td class="neosql-cell-mono">{{ row[col.name] ?? '—' }}</td>
                        {% endfor %}
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="{{ columns|length }}" class="neosql-empty">{{ translate('Aucune donnée.') }}</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>

        {% if totalPages > 1 %}
            <div class="neosql-pagination">
                {% for p in 1..totalPages %}
                    <a href="{{ path('panel.neosql.table.show', {table: table}) }}?page={{ p }}"
                       class="neosql-page-link{{ p == page ? ' active' : '' }}">{{ p }}</a>
                {% endfor %}
            </div>
        {% endif %}
    </div>
{% endblock %}