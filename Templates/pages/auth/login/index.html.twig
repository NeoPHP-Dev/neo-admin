{# ./src/Neo_Admin/Templates/pages/auth/login/index.html.twig #}

{% extends "layouts/base.layout.html.twig" %}

{% block content %}

    <div class="login-page">
        <div class="login-card">
            <div class="login-header">
                <div class="login-logo">
                    <i data-lucide="shield-check" class="w-6 h-6"></i>
                </div>
                <h1 class="login-title">
                    {{ app.name }}
                </h1>
                <p class="login-subtitle">
                    {{ translate('Connectez-vous à :appName dès maintenant !', {appName: app.name}, 'login') }}
                </p>
            </div>

            {% if form_errors(loginForm) is not empty %}
                <div class="form-errors">
                    {% for error in form_errors(loginForm) %}
                        <span class="error">
                            {{ error }}
                        </span>
                    {% endfor %}
                </div>
            {% endif %}

            {{ form_start(loginForm) }}
                {{ form_csrf(loginForm) }}

                <div class="login-field">
                    {{ form_label(loginForm, 'username') }}
                    <div class="login-input-wrap">
                        <i data-lucide="user" class="login-icon"></i>
                        {{ form_widget(loginForm, 'username') }}
                    </div>
                    {% for error in form_error(loginForm, 'username') %}
                        <span class="error">
                            {{ error }}
                        </span>
                    {% endfor %}
                </div>

                <div class="login-field">
                    {{ form_label(loginForm, 'password') }}
                    <div class="login-input-wrap" data-password-wrap>
                        <i data-lucide="lock" class="login-icon"></i>
                        {{ form_widget(loginForm, 'password') }}
                        <button type="button" class="login-toggle-password" data-toggle-password>
                            <i data-lucide="eye" class="w-4 h-4"></i>
                        </button>
                    </div>
                    {% for error in form_error(loginForm, 'password') %}
                        <span class="error">
                            {{ error }}
                        </span>
                    {% endfor %}
                </div>

                {{ form_widget(loginForm, 'submit', {label: 'Se connecter', attr: {class: 'login-submit'}}) }}

            {{ form_end() }}

            <p class="login-footer">{{ app.name }} &copy; {{ "now"|date("Y") }}</p>
        </div>
    </div>

    <script>
        document.querySelectorAll('[data-toggle-password]').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var wrap = btn.closest('[data-password-wrap]');
                var input = wrap.querySelector('input');
                input.type = input.type === 'password' ? 'text' : 'password';
            });
        });
    </script>

{% endblock %}
